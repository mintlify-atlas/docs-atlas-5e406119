  "keyFeatures": [
    "Privacy-preserving cross-media measurement using secure multiparty computation",
    "Distributed architecture with Kingdom controller and multiple Duchy nodes",
    "Support for reach and frequency estimation with differential privacy",
    "Kubernetes-native deployment on GKE and EKS",
    "Cryptographic protocols for encrypted sketch computation",
    "Multi-cloud support for enhanced security guarantees"
  ],
  "publicApiSurface": [
    "MeasurementsService - Create and manage measurement reports",
    "RequisitionsService - Fulfill data requisitions from publishers",
    "EventGroupsService - Manage event data groups",
    "DataProvidersService - Register and manage data providers",
    "ComputationControlService - Control secure computation execution",
    "ReportingService - Generate and retrieve reports",
    "PermissionsService - Manage access permissions",
    "PoliciesService - Configure access policies"
  ]
